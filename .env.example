# Application
PROJECT_NAME="AI Document Q&A Service"
API_V1_STR="/api/v1"
DEBUG=True

# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/rag_db

# Providers Configuration
# LLM_PROVIDER can be 'openai', 'ollama', etc.
LLM_PROVIDER=openai
# EMBEDDING_PROVIDER can be 'openai', 'sentence-transformers', etc.
EMBEDDING_PROVIDER=openai

# Vector Database
# VECTOR_DB can be 'pgvector' or 'chroma'
VECTOR_DB=chroma

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# RAG Settings
TOP_K=5
CHUNK_SIZE=500
CHUNK_OVERLAP=50
SIMILARITY_THRESHOLD=0.75
